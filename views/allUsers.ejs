<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body>
    <div class="d-flex flex-wrap gap-3" style="padding: 20px;">
        <% users.forEach((user, index) => {%>
            <div class="card" style="width: 18rem;">
                <div class="card-body">
                    <h5 class="card-title"><%= user.fullname %></h5>
                    <h6 class="card-subtitle mb-2 text-body-secondary"><%= user.email %></h6>
                    <p class="card-text"><%= user.course %></p>
                    <p class="card-text">Age: <%= user.age %></p>
                    <div class="d-flex gap-2">
                        <form action="/deleteuser/<%= index %>" method="POST">
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </form>
                        <a href="/edituser/<%= index %>" class="btn btn-primary">Edit</a>
                    </div>
                </div>
            </div>
                    <% }); %>
    </div>

    <!-- <div class ="d-flex flex-wrap gap-3" style="padding: 20px;">
        <% for(let index = 0; index < users.length; index++) { %>
        <div class="card" style="width: 18rem; padding: 10px;">
            <p><%= users[index].fullname %></p>
            <p><%= users[index].email %></p>
            <p><%= users[index].course %></p>
            <h6><%= users[index].age %></h6>
        </div>
        <% } %>
    </div> -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html> 